# =========================================================================
# Voice Agent configuration. Copy to `.env` and fill in your values.
# All variables are prefixed with VA_ and read by config/settings.py.
# =========================================================================

# ---- OpenAI ----
VA_OPENAI_API_KEY=sk-...
# Chat / reasoning model used by the agent loop.
VA_LLM_MODEL=gpt-5
# Realtime model (used when realtime voice is enabled).
VA_REALTIME_MODEL=gpt-4o-realtime-preview
# Speech-to-text model.
VA_STT_MODEL=whisper-1
# Text-to-speech model + voice.
VA_TTS_MODEL=gpt-4o-mini-tts
VA_TTS_VOICE=alloy
# Vision model for screenshot / UI understanding.
VA_VISION_MODEL=gpt-5

# ---- Voice behaviour ----
VA_WAKE_WORDS=hey assistant,jarvis
VA_ENABLE_WAKE_WORD=true
VA_SILENCE_TIMEOUT_MS=1200
VA_SAMPLE_RATE=16000

# ---- GUI ----
VA_THEME=dark
VA_ANIMATION_SPEED=1.0
VA_ACCENT_COLOR=#22d3ee

# ---- Agent ----
VA_MAX_AGENT_STEPS=12
VA_ENABLE_AUTOMATION=true
# Require confirmation before destructive tools (delete/close/etc.)
VA_CONFIRM_DESTRUCTIVE=true

# ---- Storage ----
VA_DB_PATH=database/voice_agent.db
VA_LOG_DIR=logs
VA_LOG_LEVEL=INFO

# ---- Backend ----
VA_API_HOST=127.0.0.1
VA_API_PORT=8765
